<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                      https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
  version="6.0">
    <context-param>
        <param-name>jakarta.faces.PROJECT_STAGE</param-name>
        <param-value>Development</param-value>
    </context-param>
    <listener>
        <listener-class>com.aisthea.fashion.listener.SessionListener</listener-class>
    </listener>
    <filter>
        <filter-name>UrlRewriteFilter</filter-name>
        <filter-class>com.aisthea.fashion.filter.UrlRewriteFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>UrlRewriteFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <servlet>
        <servlet-name>ProductServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.ProductServlet</servlet-class>
        <multipart-config>
            <file-size-threshold>2097152</file-size-threshold>
            <max-file-size>20971520</max-file-size>
            <max-request-size>104857600</max-request-size>
            <file-count-limit>100</file-count-limit>
        </multipart-config>
    </servlet>
    <servlet>
        <servlet-name>CategoryServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.CategoryServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ActivateServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.ActivateServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ResetRequestServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.ResetRequestServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.ProfileServlet</servlet-class>
        <multipart-config>
            <file-size-threshold>1048576</file-size-threshold>
            <max-file-size>5242880</max-file-size>
            <max-request-size>10485760</max-request-size>
        </multipart-config>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.ResetPasswordServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CartServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.CartServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UserServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.UserServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>OrderServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.OrderServlet</servlet-class>
        <multipart-config>
            <file-size-threshold>2097152</file-size-threshold> <!-- 2MB -->
            <max-file-size>10485760</max-file-size> <!-- 10MB -->
            <max-request-size>52428800</max-request-size> <!-- 50MB -->
        </multipart-config>
    </servlet>
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.DashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GoogleLoginServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.GoogleLoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.HomeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ImageServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.ImageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ImageServlet</servlet-name>
        <url-pattern>/uploads/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>Faces Servlet</servlet-name>
        <servlet-class>jakarta.faces.webapp.FacesServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductServlet</servlet-name>
        <url-pattern>/product</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CategoryServlet</servlet-name>
        <url-pattern>/category</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ActivateServlet</servlet-name>
        <url-pattern>/activate</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ResetRequestServlet</servlet-name>
        <url-pattern>/forgot-password</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/profile</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/updateProfile</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <url-pattern>/reset</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CartServlet</servlet-name>
        <url-pattern>/cart</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CartServlet</servlet-name>
        <url-pattern>/checkout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UserServlet</servlet-name>
        <url-pattern>/user</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>OrderServlet</servlet-name>
        <url-pattern>/order</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>
    <!-- Move this to after servlet definition -->
    <servlet>
        <servlet-name>ChangePasswordServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.ChangePasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ChangePasswordServlet</servlet-name>
        <url-pattern>/change-password</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GoogleLoginServlet</servlet-name>
        <url-pattern>/google-login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>TierDetailServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.TierDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TierDetailServlet</servlet-name>
        <url-pattern>/tier-details</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>AddressServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.AddressServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddressServlet</servlet-name>
        <url-pattern>/address</url-pattern>
    </servlet-mapping>


    <servlet>
        <servlet-name>NotificationApiServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.NotificationApiServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>NotificationApiServlet</servlet-name>
        <url-pattern>/notifications/api</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>StylistServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.StylistServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StylistServlet</servlet-name>
        <url-pattern>/stylist</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>FeedbackServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.FeedbackServlet</servlet-class>
        <multipart-config>
            <file-size-threshold>1048576</file-size-threshold>
            <max-file-size>5242880</max-file-size>
            <max-request-size>10485760</max-request-size>
            <file-count-limit>20</file-count-limit>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>FeedbackServlet</servlet-name>
        <url-pattern>/feedback</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>VoucherServlet</servlet-name>
        <servlet-class>com.aisthea.fashion.controller.VoucherServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>VoucherServlet</servlet-name>
        <url-pattern>/voucher</url-pattern>
    </servlet-mapping>
    <!-- HomeServlet mapped to / handles root URL directly -->

    <servlet-mapping>
        <servlet-name>Faces Servlet</servlet-name>
        <url-pattern>/faces/*</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>home</welcome-file>
    </welcome-file-list>
</web-app>
